// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  nickname  String   @unique
  telegram  String
  tgChannel String
  vkLink    String
  roles     String   // Store as JSON string, e.g., ["DUBBER", "TIMER"]
  
  assignments RoleAssignment[]
  substitutions RoleAssignment[] @relation("Substitute")
  uploads     UploadedFile[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                String    @id @default(uuid())
  title             String
  status            String    // "ACTIVE", "COMPLETED"
  lastActiveEpisode Int       @default(1)
  totalEpisodes     Int       @default(12)
  links             String?   // JSON string: { "anime365": "...", "tg": "...", "kodik": "...", "vk": "...", "shikimori": "..." }
  globalMapping     String?   // JSON string: { "CharacterName": "DubberUserId" }
  episodes          Episode[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Episode {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number    Int
  status    String   // "UPLOAD", "ROLES", "RECORDING", "QA", "FIXES", "SOUND_ENGINEERING", "FINISHED"
  deadline  DateTime?
  
  rawPath   String?
  subPath   String?
  
  assignments RoleAssignment[]
  uploads     UploadedFile[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoleAssignment {
  id            String  @id @default(uuid())
  episodeId     String
  episode       Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  characterName String
  dubberId      String
  dubber        User    @relation(fields: [dubberId], references: [id], onDelete: Cascade)
  status        String  @default("PENDING") // "PENDING", "RECORDED", "APPROVED", "REJECTED", "FIXES_NEEDED"
  uploads       UploadedFile[]
  
  substituteId  String?
  substitute    User?   @relation("Substitute", fields: [substituteId], references: [id])
}

model UploadedFile {
  id        String  @id @default(uuid())
  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  assignmentId String?
  assignment   RoleAssignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  type      String  // "DUBBER_FILE", "FIXES"
  path      String
  uploadedById String
  uploadedBy   User    @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
