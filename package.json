{
  "name": "anime-dub-manager",
  "version": "1.0.0",
  "description": "Гибридное кроссплатформенное десктопное приложение для студии озвучки и фандаба.",
  "author": "Svat.Owl",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "vite build && electron-builder",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.dubbing.app",
    "productName": "Anime Dub Manager",
    "icon": "assets/icon.png",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "ass-compiler": "^0.1.16",
    "axios": "^1.14.0",
    "dotenv": "^17.2.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "wavesurfer.js": "^7.12.5"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
