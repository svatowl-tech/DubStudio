{
  "name": "anime-dub-manager",
  "version": "1.0.0",
  "description": "Гибридное кроссплатформенное десктопное приложение для студии озвучки и фандаба.",
  "author": "Svat.Owl",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "node scripts/generate-metadata.js && vite build && electron-builder",
    "build": "node scripts/generate-metadata.js && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "@google-cloud/speech": "^7.3.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "ass-compiler": "^0.1.16",
    "axios": "^1.15.0",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-joyride": "^3.0.2",
    "tesseract.js": "^7.0.0",
    "vite": "^6.2.0",
    "wavesurfer.js": "^7.12.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "glob": "^13.0.0",
    "rimraf": "^6.0.0"
  }
}
