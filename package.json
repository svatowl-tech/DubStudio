{
  "name": "anime-dub-manager",
  "version": "1.1.0",
  "description": "Гибридное кроссплатформенное десктопное приложение для студии озвучки и фандаба.",
  "author": "Svat.Owl <Svat.Owl@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "node scripts/generate-metadata.js && node scripts/download-ffmpeg.js && vite build && electron-builder",
    "build:electron": "npm run electron:build",
    "prebuild": "echo 'ONNX check skipped during build'",
    "build": "node scripts/generate-metadata.js && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@xenova/transformers": "^2.17.2",
    "ass-compiler": "^0.1.16",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.474.0",
    "motion": "^12.0.1",
    "onnxruntime-web": "^1.20.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-joyride": "^2.9.3",
    "sonner": "^1.7.2",
    "tesseract.js": "^5.1.1",
    "wavesurfer.js": "^7.8.10",
    "webtorrent": "^3.0.11",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.1",
    "vitest": "^3.0.5"
  },
  "overrides": {
    "glob": "^11.0.0",
    "rimraf": "^6.0.0",
    "nanoid": "^3.3.8",
    "micromatch": "^4.0.8",
    "cross-spawn": "^7.0.6",
    "axios": "^1.7.9",
    "tar": "^7.4.3",
    "semver": "^7.6.3",
    "ws": "^8.18.0",
    "esbuild": "0.25.0",
    "rollup": "^4.32.1",
    "follow-redirects": "^1.15.12",
    "protobufjs": "^7.5.5",
    "onnxruntime-node": "npm:onnxruntime-web@1.20.1",
    "react-joyride": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
